{
  "manifest_version": 3,
  "name": "DarkSparx",
  "version": "1.0",
  "description": "Dark Mode for Sparx Maths",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://maths.sparx-learning.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "host_permissions": [
    "https://maths.sparx-learning.com/*"
  ]
}